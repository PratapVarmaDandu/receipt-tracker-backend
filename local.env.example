# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT SECRETS
# Copy this file to  backend/local.env  and fill in your real values.
# backend/local.env  is gitignored and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth2 (from console.cloud.google.com) ────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# ── Credential encryption key (any random string, min 32 chars) ──────────────
ENCRYPTION_SECRET=change-this-to-a-random-32-char-string

# ── Claude Vision AI (optional — leave blank to use Tesseract OCR only) ──────
ANTHROPIC_API_KEY=sk-ant-your-key-here
VISION_AI_ENABLED=true
