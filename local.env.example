VISION_AI_ENABLED=true

# ── New Relic APM (optional — leave blank to skip APM entirely) ───────────────
# NR_LICENSE_KEY:  Settings → API Keys → License Key (ingest key, not user key)
# NR_APP_NAME:     Display name in the New Relic UI
# When NR_LICENSE_KEY is set, start.sh attaches -javaagent:newrelic/newrelic.jar.
# First-time JAR download:  cd receipt-tracker-backend && mvn package -Pnewrelic
NR_LICENSE_KEY=
NR_APP_NAME=steward-dev
