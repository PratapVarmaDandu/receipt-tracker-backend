# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT SECRETS
# Copy this file to  receipt-tracker-backend/local.env  and fill in real values.
# receipt-tracker-backend/local.env  is gitignored and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth2 (from console.cloud.google.com) ────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Credential encryption key (any random string, min 32 chars) ──────────────
ENCRYPTION_SECRET=change-this-to-a-random-32-char-string

# ── Gmail SMTP (for expense-share invitation emails) ─────────────────────────
# Create a Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
# Enter the 16-char password WITHOUT spaces (e.g. abcdwxyz12345678)
# Leave blank to fall back to console-log output (no emails sent).
GMAIL_USERNAME=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── Claude Vision AI (optional — leave blank to use Tesseract OCR only) ──────
ANTHROPIC_API_KEY=sk-ant-your-key-here
VISION_AI_ENABLED=true

# ── New Relic APM (optional — leave blank to skip APM entirely) ───────────────
# NR_LICENSE_KEY:  Settings → API Keys → License Key (ingest key, not user key)
# NR_APP_NAME:     Display name in the New Relic UI
# When NR_LICENSE_KEY is set, start.sh attaches -javaagent:newrelic/newrelic.jar
# First-time JAR download:  cd receipt-tracker-backend && mvn package -Pnewrelic
NR_LICENSE_KEY=
NR_APP_NAME=steward-dev
